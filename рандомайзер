import random
import io
import os
from PIL import Image, ImageDraw, ImageFont

from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import (
    ApplicationBuilder,
    CommandHandler,
    CallbackQueryHandler,
    ContextTypes
)

saved_number = None


def generate_image(number):
    image = Image.new('RGB', (400, 200), color='white')
    draw = ImageDraw.Draw(image)

    try:
        font = ImageFont.truetype("arial.ttf", 60)
    except:
        font = ImageFont.load_default()

    draw.text((120, 70), str(number), fill='blue', font=font)

    buffer = io.BytesIO()
    image.save(buffer, format='PNG')
    buffer.seek(0)
    return buffer


def get_number():
    global saved_number
    if saved_number is not None:
        return saved_number
    return random.randint(1, 1000)


async def send_number(update: Update, context: ContextTypes.DEFAULT_TYPE):
    number = get_number()
    img = generate_image(number)

    keyboard = [
        [InlineKeyboardButton("🔄 Ещё раз", callback_data="reroll")]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)

    if update.message:
        await update.message.reply_photo(photo=img, reply_markup=reply_markup)
    else:
        await update.callback_query.message.reply_photo(photo=img, reply_markup=reply_markup)


async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await send_number(update, context)


async def reroll(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    await send_number(update, context)


async def set_number(update: Update, context: ContextTypes.DEFAULT_TYPE):
    global saved_number

    if context.args:
        saved_number = int(context.args[0])
        await update.message.reply_text(f"Установлено число: {saved_number}")
    else:
        saved_number = None
        await update.message.reply_text("Режим сброшен (рандом)")


def main():
    token = os.getenv("TOKEN")
    app = ApplicationBuilder().token(token).build()

    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("set", set_number))
    app.add_handler(CallbackQueryHandler(reroll, pattern="reroll"))

    print("Bot started...")
    app.run_polling()


if name == "main":
    main()
